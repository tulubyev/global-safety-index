DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=safety_db
DATABASE_URL=postgres://user:password@host:5432/safety_db

REDIS_URL=redis://localhost:6379
ML_SERVICE_URL=http://localhost:8000
PORT=3001

# ACLED — register at https://acleddata.com/register/ (myACLED account)
ACLED_EMAIL=your@email.com
ACLED_PASSWORD=your_myacled_password

# ReliefWeb — register appname at https://apidoc.reliefweb.int/parameters#appname (~1 business day)
RELIEFWEB_APPNAME=your-approved-appname

# FCM push notifications (optional)
FCM_SERVER_KEY=your_fcm_server_key_here
